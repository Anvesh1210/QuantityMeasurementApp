# ===============================
# Docker Environment Variables
# ===============================
# Copy this file to .env and fill in the actual values

# ===============================
# MySQL Database Configuration
# ===============================
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=quantitymeasurementapp
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# ===============================
# Spring Boot Application Database Connection
# ===============================
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/quantitymeasurementapp
SPRING_DATASOURCE_USERNAME=app_user
SPRING_DATASOURCE_PASSWORD=app_password

# ===============================
# JWT Security Configuration
# ===============================
APP_JWT_SECRET=YourSecureJWTSecretKeyChangeThisInProduction12345678
APP_JWT_EXPIRATION_MS=3600000

# ===============================
# Application Authentication
# ===============================
APP_AUTH_NAME=App User
APP_AUTH_EMAIL=appuser@example.com
APP_AUTH_PASSWORD=app_password_123
APP_AUTH_MOBILE_NUMBER=+15555550123
APP_AUTH_ROLES=ROLE_USER

# ===============================
# OAuth2 Configuration
# ===============================
APP_OAUTH2_REDIRECT_URI=http://localhost:4200/oauth2/callback

# ===============================
# Google OAuth2 (Optional)
# ===============================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
